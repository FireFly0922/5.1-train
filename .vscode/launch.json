{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "cwd": "${workspaceRoot}",
            "executable": "./build/Debug/main.elf",
            "name": "OpenOCD Debug (halt at main)",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                                "D:/xpack-openocd-0.12.0-7/openocd/scripts/interface/stlink.cfg",
                                "D:/xpack-openocd-0.12.0-7/openocd/scripts/target/stm32h7x.cfg",

            ],
            "gdbPath": "arm-none-eabi-gdb",
            "overrideLaunchCommands": [
            "monitor reset halt"
            ],
            "searchDir": [],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        },
        {
            "name": "OpenOCD Attach (do not reflash)",
            "cwd": "${workspaceRoot}",
            "executable": "./build/Debug/main.elf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "openocd",
            "configFiles": [
                                "D:/xpack-openocd-0.12.0-7/openocd/scripts/interface/stlink.cfg",
                                "D:/xpack-openocd-0.12.0-7/openocd/scripts/target/stm32h7x.cfg",

            ],
            "gdbPath": "arm-none-eabi-gdb",
            "searchDir": [],
            "showDevDebugOutput": "none"
        },
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "executable": "./bin/executable.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "jlink"
        }
    ]
}
